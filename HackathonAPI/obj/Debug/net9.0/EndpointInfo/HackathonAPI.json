  "components": {
    "schemas": {
      "ChallengeReadDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "code": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ChallengeWithMembersDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "code": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MemberDTO": {
        "required": [
          "category",
          "dob",
          "firstName",
          "lastName",
          "memberCode",
          "organization",
          "skillRating",
          "yearsExperience"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "middleName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "memberCode": {
            "maxLength": 7,
            "minLength": 0,
            "pattern": "^\\d{7}$",
            "type": "string"
          },
          "dob": {
            "type": "string",
            "format": "date"
          },
          "skillRating": {
            "maximum": 10,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "yearsExperience": {
            "maximum": 20,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "category": {
            "minLength": 1,
            "pattern": "^[JA]$",
            "type": "string"
          },
          "organization": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "regionID": {
            "type": "integer",
            "format": "int32"
          },
          "challengeID": {
            "type": "integer",
            "format": "int32"
          },
          "rowVersion": {
            "type": "string",
            "format": "byte",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegionReadDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "code": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegionWithMembersDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "code": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemberDTO"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
